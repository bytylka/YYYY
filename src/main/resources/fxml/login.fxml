<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.store.app.controllers.LoginController"
      prefWidth="400" prefHeight="300">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Вход в магазин" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <VBox spacing="10">
        <TextField fx:id="usernameField" promptText="Имя пользователя"/>
        <PasswordField fx:id="passwordField" promptText="Пароль"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Войти" onAction="#handleLogin" prefWidth="100"
                style="-fx-background-color: #89b4fa; -fx-text-fill: #1e1e2e;"/>
        <Button text="Регистрация" onAction="#handleRegister" prefWidth="120"
                style="-fx-background-color: transparent; -fx-border-color: #89b4fa; -fx-text-fill: #89b4fa;"/>
    </HBox>

    <Label fx:id="statusLabel" text="" wrapText="true"/>
</VBox>