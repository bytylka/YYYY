<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<?import javafx.geometry.Insets?>
<VBox spacing="15" alignment="CENTER" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.store.app.controllers.ProfileController" style="-fx-padding: 30;">

    <Label text="Настройки профиля" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <ImageView fx:id="avatarView" fitHeight="80" fitWidth="80" preserveRatio="true"/>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Логин:"/>
        <TextField fx:id="nameField"/>
    </HBox>

    <TextArea fx:id="aboutArea" promptText="Расскажите о себе..." prefRowCount="3"/>

    <ComboBox fx:id="themeBox"/>
    <Button text="Назад в магазин" onAction="#goToStore"
            style="-fx-background-color: #89b4fa; -fx-text-fill: white;
               -fx-font-weight: bold; -fx-padding: 8 16;"/>
    <Button text="Сохранить" onAction="#handleSave" prefWidth="150" style="-fx-background-color: #2ecc71;"/>
</VBox>
